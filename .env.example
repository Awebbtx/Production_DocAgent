DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
OUTPUT_DIR=output
STYLE_SHEET_PATH=styles/report.css
HTML_TEMPLATE_PATH=templates/report.html.j2

# Auth and user account system
AUTH_DB_PATH=output/auth.db
AUTH_SECRET_KEY=change-me-in-production
AUTH_SESSION_COOKIE_NAME=docagent_session
AUTH_SESSION_TTL_SECONDS=43200
AUTH_COOKIE_SECURE=true

# Optional first-time bootstrap admin account (created only if user table is empty)
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_CREDENTIALS_PATH=output/bootstrap-admin-credentials.txt