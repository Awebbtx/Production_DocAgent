# IT Doc Builder production environment for docagent.iknowapro.net
# Copy to /opt/it-docbuilder/.env on the host and adjust values.

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

OUTPUT_DIR=/opt/it-docbuilder/output
STYLE_SHEET_PATH=/opt/it-docbuilder/styles/report.css
HTML_TEMPLATE_PATH=/opt/it-docbuilder/templates/report.html.j2

# Auth data store and session security
AUTH_DB_PATH=/opt/it-docbuilder/output/auth.db
AUTH_SECRET_KEY=REPLACE_WITH_LONG_RANDOM_SECRET
AUTH_SESSION_COOKIE_NAME=docagent_session
AUTH_SESSION_TTL_SECONDS=43200
AUTH_COOKIE_SECURE=true

# Bootstrap admin is only used when user table is empty
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=REPLACE_WITH_STRONG_TEMP_PASSWORD
