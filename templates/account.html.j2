<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>DocAgent Account</title>
    <style>
        :root {
            --night: #0f1b2d;
            --steel: #24415d;
            --ember: #c85c2b;
            --sand: #f4efe7;
            --paper: #fcfaf5;
            --line: #d6c8b7;
            --text: #1a2430;
            --muted: #5e6d78;
            --accent: #2f6f4f;
            --warn: #a5482a;
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            color: var(--text);
            background:
                radial-gradient(circle at top right, rgba(200, 92, 43, 0.15), transparent 28%),
                linear-gradient(180deg, #e6ebef 0%, var(--sand) 100%);
        }
        .shell {
            width: min(1240px, calc(100vw - 32px));
            margin: 24px auto 40px;
            display: grid;
            gap: 14px;
        }
        .topbar {
            background: linear-gradient(135deg, rgba(15, 27, 45, 0.98), rgba(36, 65, 93, 0.92));
            color: #fff;
            padding: 28px;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(15, 27, 45, 0.2);
        }
        .topbar strong {
            display: block;
            font-family: Georgia, "Times New Roman", serif;
            font-size: clamp(1.6rem, 2.6vw, 2.1rem);
            font-weight: 700;
            margin-bottom: 6px;
            color: white;
        }
        .topbar-sub {
            margin: 0;
            color: rgba(255, 255, 255, 0.82);
        }
        .links { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
        .links a, .links button {
            border: 0;
            border-radius: 999px;
            padding: 8px 12px;
            font: inherit;
            font-size: 0.82rem;
            font-weight: 700;
            text-decoration: none;
            cursor: pointer;
            background: rgba(255,255,255,0.88);
            color: #12314b;
        }
        .links a.current {
            background: linear-gradient(135deg, #e9dfd2, #d7c7b2);
            color: var(--steel);
            pointer-events: none;
        }
        .panel {
            background: var(--paper);
            border: 1px solid var(--line);
            border-radius: 24px;
            box-shadow: 0 18px 44px rgba(36, 65, 93, 0.08);
            padding: 18px;
        }
        .panel h2 {
            margin: 0 0 10px;
            font-family: Georgia, "Times New Roman", serif;
            color: var(--night);
        }
        label { display: block; font-weight: 700; margin: 0 0 6px; color: #243c52; }
        input {
            width: 100%;
            border: 1px solid #c8b8a5;
            border-radius: 10px;
            padding: 10px;
            font: inherit;
            background: #fff;
            margin-bottom: 10px;
        }
        button {
            border: 0;
            border-radius: 999px;
            padding: 9px 13px;
            font: inherit;
            font-weight: 700;
            cursor: pointer;
            color: #fff;
            background: linear-gradient(135deg, var(--accent), #164a43);
        }
        .danger { background: linear-gradient(135deg, #c45d3a, #9b3c21); }
        .status { min-height: 20px; color: var(--muted); font-size: 0.92rem; }
        .error { color: var(--warn); }

        @media (max-width: 980px) {
            .shell {
                width: min(100vw - 20px, 1240px);
            }
        }
    </style>
</head>
<body>
    <div class="shell">
        <header class="topbar">
            <div class="links">
                <a href="/app">Open Builder</a>
                <a href="/history">History</a>
                {% if is_admin %}<a href="/settings">Settings</a>{% endif %}
                <a href="/account" class="current" aria-current="page">My Account</a>
                <button id="logout" type="button">Logout</button>
            </div>
            <div>
                <strong>Account: {{ username }}</strong>
                <p class="topbar-sub">Manage your password, MFA, and usage in one place. Powered by IKAP Systems.</p>
            </div>
        </header>

        <section class="panel">
            <h2>Daily Generation Usage</h2>
            <div id="usage" class="status">Loading usage...</div>
        </section>

        <section class="panel">
            <h2>My Builder Presets</h2>
            <p>These values auto-populate your document builder form.</p>
            <label for="default-author">Default Author</label>
            <input id="default-author" type="text" placeholder="e.g. Jane Doe">
            <label for="default-company">Default Company Name</label>
            <input id="default-company" type="text" placeholder="e.g. Acme Corporation">
            <button id="save-defaults" type="button">Save Presets</button>
            <div id="defaults-status" class="status"></div>
        </section>

        <section class="panel">
            <h2>Change Password</h2>
            <label for="current">Current Password</label>
            <input id="current" type="password" autocomplete="current-password">
            <label for="new">New Password</label>
            <input id="new" type="password" autocomplete="new-password">
            <button id="change-pass" type="button">Update Password</button>
        </section>

        <section class="panel">
            <h2>Reset MFA</h2>
            <p>Resetting MFA logs you out. Next login requires MFA re-enrollment with QR.</p>
            <label for="mfa-current">Current Password</label>
            <input id="mfa-current" type="password" autocomplete="current-password">
            <button id="reset-mfa" class="danger" type="button">Reset My MFA</button>
        </section>

        <div id="status" class="status"></div>
    </div>

    <script>
        const statusBox = document.getElementById("status");
        const usageBox = document.getElementById("usage");
        const logoutBtn = document.getElementById("logout");
        const defaultAuthorInput = document.getElementById("default-author");
        const defaultCompanyInput = document.getElementById("default-company");
        const saveDefaultsBtn = document.getElementById("save-defaults");
        const defaultsStatus = document.getElementById("defaults-status");

        function status(message, isError = false) {
            statusBox.textContent = message;
            statusBox.classList.toggle("error", isError);
        }

        async function loadUsage() {
            try {
                const response = await fetch("/account/usage");
                if (!response.ok) {
                    throw new Error("Unable to load usage.");
                }
                const data = await response.json();
                if (data.daily_doc_limit === null) {
                    usageBox.textContent = `Used today: ${data.used_today}. Limit: unlimited.`;
                } else {
                    usageBox.textContent = `Used today: ${data.used_today}. Remaining: ${data.remaining_today}/${data.daily_doc_limit}.`;
                }
            } catch (error) {
                usageBox.textContent = error.message || "Unable to load usage.";
            }
        }

        async function loadAccountDefaults() {
            try {
                const response = await fetch("/account/defaults");
                if (!response.ok) throw new Error("Unable to load account presets.");
                const data = await response.json();
                defaultAuthorInput.value = data.author || "";
                defaultCompanyInput.value = data.company_name || "";
                defaultsStatus.textContent = "Presets loaded.";
                defaultsStatus.classList.remove("error");
            } catch (error) {
                defaultsStatus.textContent = error.message || "Unable to load account presets.";
                defaultsStatus.classList.add("error");
            }
        }

        saveDefaultsBtn.addEventListener("click", async () => {
            try {
                const response = await fetch("/account/defaults", {
                    method: "POST",
                    headers: {"Content-Type": "application/json"},
                    body: JSON.stringify({
                        author: defaultAuthorInput.value.trim(),
                        company_name: defaultCompanyInput.value.trim(),
                    }),
                });
                if (!response.ok) {
                    const err = await response.json();
                    throw new Error(err.detail || "Unable to save account presets.");
                }
                defaultsStatus.textContent = "Presets saved.";
                defaultsStatus.classList.remove("error");
            } catch (error) {
                defaultsStatus.textContent = error.message || "Unable to save account presets.";
                defaultsStatus.classList.add("error");
            }
        });

        document.getElementById("change-pass").addEventListener("click", async () => {
            const currentPassword = document.getElementById("current").value;
            const newPassword = document.getElementById("new").value;
            try {
                const response = await fetch("/account/change-password", {
                    method: "POST",
                    headers: {"Content-Type": "application/json"},
                    body: JSON.stringify({ current_password: currentPassword, new_password: newPassword }),
                });
                if (!response.ok) {
                    const err = await response.json();
                    throw new Error(err.detail || "Password update failed.");
                }
                document.getElementById("current").value = "";
                document.getElementById("new").value = "";
                status("Password updated successfully.");
            } catch (error) {
                status(error.message || "Password update failed.", true);
            }
        });

        document.getElementById("reset-mfa").addEventListener("click", async () => {
            const currentPassword = document.getElementById("mfa-current").value;
            if (!currentPassword) {
                status("Enter current password to reset MFA.", true);
                return;
            }
            try {
                const response = await fetch("/account/reset-mfa", {
                    method: "POST",
                    headers: {"Content-Type": "application/json"},
                    body: JSON.stringify({ current_password: currentPassword }),
                });
                if (!response.ok) {
                    const err = await response.json();
                    throw new Error(err.detail || "MFA reset failed.");
                }
                window.location.href = "/";
            } catch (error) {
                status(error.message || "MFA reset failed.", true);
            }
        });

        logoutBtn.addEventListener("click", async () => {
            await fetch("/auth/logout", { method: "POST" });
            window.location.href = "/";
        });

        loadUsage();
        loadAccountDefaults();
    </script>
</body>
</html>
