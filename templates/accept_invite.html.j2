<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Accept Invitation - DocAgent</title>
    <style>
        body { margin: 0; font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif; background: #f4efe7; color: #1a2430; }
        .shell { width: min(620px, calc(100vw - 24px)); margin: 40px auto; background: #fcfaf5; border: 1px solid #d6c8b7; border-radius: 18px; padding: 22px; }
        h1 { margin: 0 0 10px; font-family: Georgia, "Times New Roman", serif; color: #0f1b2d; }
        .row { display: grid; gap: 8px; margin-bottom: 12px; }
        label { font-weight: 700; color: #24415d; }
        input { border: 1px solid #c8b8a5; border-radius: 10px; padding: 10px; font: inherit; width: 100%; }
        button { border: 0; border-radius: 999px; padding: 10px 14px; color: #fff; font-weight: 700; cursor: pointer; background: linear-gradient(135deg, #2f6f4f, #164a43); }
        .status { min-height: 22px; color: #5d6d79; margin-top: 10px; }
        .error { color: #af3f2b; }
    </style>
</head>
<body>
    <main class="shell">
        <h1>Accept Invitation</h1>
        <p>Create your DocAgent account.</p>
        <div class="row">
            <label for="username">Username</label>
            <input id="username" autocomplete="username">
        </div>
        <div class="row">
            <label for="password">Password</label>
            <input id="password" type="password" autocomplete="new-password">
        </div>
        <button id="accept-btn" type="button">Create Account</button>
        <div id="status" class="status"></div>
    </main>

    <script>
        const token = {{ token|tojson }};
        const statusBox = document.getElementById("status");

        function status(message, isError = false) {
            statusBox.textContent = message;
            statusBox.classList.toggle("error", isError);
        }

        document.getElementById("accept-btn").addEventListener("click", async () => {
            if (!token) {
                status("Missing invitation token.", true);
                return;
            }
            try {
                const response = await fetch("/auth/invitations/accept", {
                    method: "POST",
                    headers: {"Content-Type": "application/json"},
                    body: JSON.stringify({
                        token,
                        username: document.getElementById("username").value.trim(),
                        password: document.getElementById("password").value,
                    }),
                });
                if (!response.ok) {
                    const err = await response.json();
                    throw new Error(err.detail || "Could not accept invitation.");
                }
                status("Account created. Redirecting to login...");
                setTimeout(() => { window.location.href = "/"; }, 900);
            } catch (error) {
                status(error.message || "Could not accept invitation.", true);
            }
        });
    </script>
        <div style="text-align:center; color:#5c6a78; font-size:0.82rem; padding:8px 12px 18px;">Copyright (c) IKAP Systems</div>
    
</body>
</html>
