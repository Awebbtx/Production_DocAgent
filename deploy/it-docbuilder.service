[Unit]
Description=IT Doc Builder FastAPI Service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/it-docbuilder
EnvironmentFile=/opt/it-docbuilder/.env
ExecStart=/opt/it-docbuilder/.venv/bin/uvicorn it_doc_builder.api:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
